@@ -0,0 +1,74 @@
+.loader {
+  position: fixed;
+  inset: 0;
+  z-index: 10000;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: var(--bg);
+  transition: opacity 500ms ease, visibility 500ms ease;
+}
+
+.loader--hidden {
+  opacity: 0;
+  visibility: hidden;
+  pointer-events: none;
+}
+
+.loader-mark {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 10px;
+}
+
+.loader-mark span {
+  font-size: 12px;
+  letter-spacing: 0.35em;
+  text-transform: uppercase;
+  color: var(--fg);
+  opacity: 0;
+  animation: loader-fade 600ms ease forwards 150ms;
+}
+
+.loader-line {
+  display: block;
+  width: 64px;
+  height: 1px;
+  background: var(--accent);
+  transform: scaleX(0);
+  transform-origin: left;
+  animation: loader-draw 900ms cubic-bezier(0.16, 0.84, 0.44, 1) forwards 250ms;
+}
+
+@keyframes loader-fade {
+  to {
+    opacity: 1;
+  }
+}
+
+@keyframes loader-draw {
+  to {
+    transform: scaleX(1);
+  }
+}
+
+.site {
+  opacity: 0;
+  transform: translateY(8px);
+  transition: opacity 600ms ease, transform 600ms ease;
+}
+
+.site--visible {
+  opacity: 1;
+  transform: none;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .loader-mark span,
+  .loader-line {
+    animation: none;
+    opacity: 1;
+    transform: none;
+  }
+}
