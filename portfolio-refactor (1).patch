+/* ---------- scroll reveal ---------- */
+.reveal {
+  opacity: 0;
+  transform: translateY(28px);
+  transition: opacity 800ms var(--ease-out), transform 800ms var(--ease-out);
+  will-change: opacity, transform;
+}
+.reveal.revealed {
+  opacity: 1;
+  transform: none;
+}
+.reveal hr {
+  transform: scaleX(0);
+  transform-origin: center;
+  transition: transform 900ms var(--ease-out) 120ms;
+}
+.reveal.revealed hr {
+  transform: scaleX(1);
+}
+
+/* ---------- hover "spark" for keywords ---------- */
+.spark {
+  position: relative;
+  color: inherit;
+  cursor: default;
+  background-image: linear-gradient(var(--accent), var(--accent));
+  background-repeat: no-repeat;
+  background-position: left bottom;
+  background-size: 0% 1px;
+  transition: background-size 450ms var(--ease-out), color 450ms var(--ease-out), text-shadow 450ms var(--ease-out);
+}
+.spark:hover,
+.spark:focus-visible {
+  color: #f3d9a4;
+  background-size: 100% 1px;
+  text-shadow: 0 0 18px var(--accent-soft);
+}
+
+/* ---------- underline-draw link style, reused by footer/work links ---------- */
+.link-draw {
+  position: relative;
+  text-decoration: none;
+  color: inherit;
+  transition: color 300ms ease;
+}
+.link-draw::after {
+  content: '';
+  position: absolute;
+  left: 0;
+  bottom: -2px;
+  width: 0%;
+  height: 1px;
+  background: var(--accent);
+  transition: width 350ms var(--ease-out);
+}
+.link-draw:hover,
+.link-draw:focus-visible {
+  color: #f3d9a4;
+}
+.link-draw:hover::after,
+.link-draw:focus-visible::after {
+  width: 100%;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+    scroll-behavior: auto !important;
+  }
+}
+
 
